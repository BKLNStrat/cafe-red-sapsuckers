---
import CafeRedLayout from '../../layouts/CafeRedLayout.astro';
import { sanityClient } from 'sanity:client';
import { getLocation, getSiteContent } from '../../lib/locations';
const loc = await getLocation('cafe-red');
const content = await getSiteContent('cafe-red');

let events: any[] = [];
try {
  events = await sanityClient.fetch(
    `*[_type == "event" && restaurant == "cafe-red" && date >= now()] | order(date asc) [0...3] { title, date, description }`
  ) || [];
} catch (e) { /* no events */ }
---
<CafeRedLayout title="Cafe Red | Italian-American Dining | Kings Park, NY" currentPage="home">
  <!-- Hero -->
  <section class="relative h-[70vh] min-h-[500px]">
    <img
      src="/cafe-red/CAFERED5starsv2-4.jpg"
      alt="Cafe Red dining room"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-red-950/50"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-white text-center px-4">
      <h1 class="text-5xl md:text-7xl font-display font-bold tracking-tight">Cafe Red</h1>
      <p class="mt-3 text-lg md:text-xl font-light tracking-wide opacity-80">New American Cuisine with Italian Flair</p>
      <p class="mt-1 text-sm md:text-base font-light tracking-widest uppercase opacity-60">Brunch -- Lunch -- Dinner</p>
      <div class="flex flex-col sm:flex-row gap-3 mt-8">
        <a
          href={loc.orderUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 bg-white text-red-900 font-semibold rounded hover:bg-red-50 transition text-sm"
        >
          Order Online
        </a>
        <a
          href={loc.reservationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 border border-white text-white font-semibold rounded hover:bg-white hover:text-red-900 transition text-sm"
        >
          Make a Reservation
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-16 md:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900 mb-6">
            New American Cuisine with Italian Flair
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            A warm, woodsy spot with a full bar serving Italian fare and creative takes on American eats. Our kitchen showcases local and organic ingredients to create a menu of refined new American fare.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            {content.aboutBody || 'From housemade pastas and brunch classics to perfectly prepared steaks and seafood, Cafe Red brings warmth and character to Kings Park. Full liquor license -- enjoy cocktails, wine, and beer with your lunch or dinner.'}
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Open seven days for brunch, lunch, and dinner. Call ahead for reservations or curbside pickup.
          </p>
          <a href="/cafe-red/menu/" class="inline-block text-sm font-semibold px-6 py-3 bg-red-900 text-white rounded hover:bg-red-800 transition">
            View Our Menu
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <img src="/cafe-red/CAFERED5starsv2-35.jpg" alt="Steak dinner" class="rounded-lg w-full h-48 object-cover" />
          <img src="/cafe-red/CAFERED5starsv2-20.jpg" alt="Pasta with meatballs" class="rounded-lg w-full h-48 object-cover" />
          <img src="/cafe-red/CAFERED5starsv2-16.jpg" alt="Pancakes with berries" class="rounded-lg w-full h-48 object-cover" />
          <img src="/cafe-red/CAFERED5starsv2-24.jpg" alt="Eggs Benedict" class="rounded-lg w-full h-48 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Dishes -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900">From Our Kitchen</h2>
        <p class="mt-3 text-gray-500">Fresh ingredients, unforgettable flavors</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img src="/cafe-red/CAFERED5starsv2-33.jpg" alt="Grilled steak" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img src="/cafe-red/CAFERED5starsv2-21.jpg" alt="Mushroom pasta" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img src="/cafe-red/CAFERED5starsv2-25.jpg" alt="Eggs Benedict" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/cafe-red/gallery/" class="inline-block text-sm font-semibold px-6 py-3 border border-red-900 text-red-900 rounded hover:bg-red-900 hover:text-white transition">
          View Gallery
        </a>
      </div>
    </div>
  </section>

  {events.length > 0 && (
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900 mb-8">Upcoming Events</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {events.map((event) => (
            <div class="border border-red-100 rounded-lg p-6">
              <p class="text-sm text-gray-500 mb-2">{new Date(event.date).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })}</p>
              <h3 class="text-xl font-bold text-gray-900 mb-2">{event.title}</h3>
              {event.description && <p class="text-gray-600">{event.description}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Location Banner -->
  <section class="relative py-20 md:py-28">
    <img
      src="/cafe-red/CAFERED5starsv2-2.jpg"
      alt="Cafe Red interior"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-red-950/60"></div>
    <div class="relative z-10 text-center text-white px-4">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">Join Us in {loc.city}</h2>
      <p class="text-lg opacity-80 mb-2">{loc.address}, {loc.city}, {loc.state} {loc.zip}</p>
      <p class="text-lg opacity-80 mb-8">{loc.phone}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={loc.orderUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 bg-white text-red-900 font-semibold rounded hover:bg-red-50 transition text-sm"
        >
          Order Online
        </a>
        <a
          href={loc.reservationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 border border-white text-white font-semibold rounded hover:bg-white hover:text-red-900 transition text-sm"
        >
          Make a Reservation
        </a>
      </div>
    </div>
  </section>
</CafeRedLayout>
