}
---
<CafeRedLayout title="Menu | Cafe Red" description="Full menu at Cafe Red -- new American and Italian cuisine, brunch, lunch, dinner, and full bar in Kings Park, NY." currentPage="menu">
  <!-- Hero -->
  <section class="relative h-64 md:h-80">
    <img
      src="/cafe-red/CAFERED5starsv2-35.jpg"
      alt="Steak dinner at Cafe Red"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-red-950/60"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-white text-center px-4">
      <h1 class="text-4xl md:text-5xl font-display font-bold">Our Menu</h1>
      <p class="mt-3 text-lg opacity-80">New American cuisine with Italian flair</p>
    </div>
  </section>

  <!-- Order Online Banner -->
  <div class="bg-red-900 text-white text-center py-4 px-4">
    <p class="text-sm">
      Enjoy Cafe Red at home --
      <a href="https://www.ordercafered.com/" target="_blank" rel="noopener noreferrer" class="underline font-semibold hover:text-red-200 transition">
        Order Online for Pickup or Delivery
      </a>
    </p>
  </div>

  <!-- Menu -->
  <section class="py-16 md:py-24 bg-stone-50">
    <div class="max-w-4xl mx-auto px-4">
      {menuSections.map((section, i) => (
        <div class={i > 0 ? 'mt-16' : ''}>
          <div class="flex items-center gap-4 mb-2">
            <h2 class="text-2xl md:text-3xl font-display font-bold text-red-900 whitespace-nowrap">{section.title}</h2>
            <div class="flex-1 h-px bg-red-200"></div>
          </div>
          {section.subtitle && (
            <p class="text-sm text-gray-500 mb-6">{section.subtitle}</p>
          )}
          <div class={`grid gap-4 ${section.subtitle ? '' : 'mt-6'}`}>
            {section.items.map(item => (
              <div class="flex items-start justify-between gap-4 py-2 border-b border-gray-200 last:border-0">
                <div>
                  <span class="text-base font-medium text-gray-900">{item.name}</span>
                  {item.desc && (
                    <p class="text-sm text-gray-500 mt-0.5">{item.desc}</p>
                  )}
                </div>
                <span class="text-base text-gray-500 font-medium whitespace-nowrap">{item.price}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="mt-16 text-center">
        <p class="text-sm text-gray-500 mb-6">Prices and availability subject to change. Please inform your server of any allergies.</p>
        <a
          href="https://www.ordercafered.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 bg-red-900 text-white font-semibold rounded hover:bg-red-800 transition text-sm"
        >
          Order Online Now
        </a>
      </div>
    </div>
  </section>
</CafeRedLayout>
