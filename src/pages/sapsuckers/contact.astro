---
import SapsuckersLayout from '../../layouts/SapsuckersLayout.astro';
import { getLocation } from '../../lib/locations';
const loc = await getLocation('sapsuckers');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<SapsuckersLayout title="Contact | Sapsuckers - Hops & Grub" description={`Find Sapsuckers at ${loc.address}, ${loc.city}, ${loc.state} ${loc.zip}. Call ${loc.phone} or reserve on OpenTable.`} currentPage="contact">
  <!-- Hero -->
  <section class="relative h-48 md:h-64">
    <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-35.jpg`}
      alt="Sapsuckers exterior sign"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 flex items-center justify-center h-full">
      <h1 class="text-4xl md:text-5xl font-display font-bold text-white">Contact</h1>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Info -->
        <div>
          <h2 class="text-2xl md:text-3xl font-display font-bold text-gray-900 mb-8">Find Us</h2>

          <div class="space-y-8">
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-3">Address</h3>
              <p class="text-lg text-gray-900">{loc.address}</p>
              <p class="text-lg text-gray-900">{loc.city}, {loc.state} {loc.zip}</p>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-3">Phone</h3>
              <a href={`tel:${loc.phoneTel.replace('+', '')}`} class="text-lg text-gray-900 hover:underline">{loc.phone}</a>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-3">Hours</h3>
              <div class="space-y-2 text-gray-700">
                {loc.hours.map((h) => (
                  <div class="flex justify-between max-w-sm">
                    <span>{h.days}</span>
                    <span class="whitespace-nowrap ml-4">{h.hours}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 pt-4">
              <a
                href={loc.orderUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-center px-6 py-3 bg-gray-900 text-white font-semibold rounded hover:bg-gray-700 transition text-sm"
              >
                Order Online
              </a>
              <a
                href={loc.reservationUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-center px-6 py-3 border border-gray-900 text-gray-900 font-semibold rounded hover:bg-gray-900 hover:text-white transition text-sm"
              >
                Make a Reservation
              </a>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div>
          <div class="bg-gray-200 rounded-lg overflow-hidden aspect-square md:aspect-auto md:h-[calc(100%-3rem)] min-h-[300px]">
            <iframe
              src={loc.mapEmbedUrl || "https://maps.google.com/maps?q=Sapsuckers+Hops+%26+Grub+287+Main+St+Huntington+NY+11743&t=&z=15&ie=UTF8&iwloc=B&output=embed"}
              width="100%"
              height="100%"
              style="border:0; min-height: 300px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Sapsuckers location map"
            ></iframe>
          </div>
          <a
            href={loc.mapDirectionsUrl || "https://www.google.com/maps/dir/?api=1&destination=Sapsuckers+Hops+%26+Grub+287+Main+St+Huntington+NY+11743"}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-3 text-sm font-semibold text-gray-700 hover:text-gray-900 transition"
          >
            Get Directions
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</SapsuckersLayout>
