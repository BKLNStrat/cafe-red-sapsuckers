---
import SapsuckersLayout from '../../layouts/SapsuckersLayout.astro';
---
<SapsuckersLayout title="Sapsuckers - Hops & Grub | Huntington, NY" currentPage="home">
  <!-- Hero -->
  <section class="relative h-[70vh] min-h-[500px]">
    <img
      src="/sapsuckers/SAPSUCKERS5starsv2-65.jpg"
      alt="Sapsuckers bar interior"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-white text-center px-4">
      <img src="/brand/Sapsuckers_Hops_White.png" alt="Sapsuckers hops" class="h-14 md:h-20 w-auto mb-4" />
      <h1 class="text-5xl md:text-7xl font-display font-bold tracking-tight">Sapsuckers</h1>
      <p class="text-base md:text-lg font-light tracking-[0.3em] uppercase opacity-80 mt-2">Hops & Grub</p>
      <p class="text-lg md:text-xl font-light tracking-widest uppercase opacity-70 mt-4">Migrate Less, Drink Local</p>
      <div class="flex flex-col sm:flex-row gap-3 mt-8">
        <a
          href="https://www.ordersapsuckers.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 bg-white text-gray-900 font-semibold rounded hover:bg-gray-100 transition text-sm"
        >
          Order Online
        </a>
        <a
          href="https://www.opentable.com/r/sapsuckers-hops-and-grub-huntington"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 border border-white text-white font-semibold rounded hover:bg-white hover:text-gray-900 transition text-sm"
        >
          Make a Reservation
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 md:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900 mb-6">
            Your Neighborhood Favorite Since 2010
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Hatched in September 2010, Sapsuckers has become a neighborhood favorite for awesome hops & grub. We keep sixteen lines of craft beers rotating -- all small production and special, many rare and extremely limited. Our Field Guide To Beer gives each one the respect it deserves.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            From the kitchen comes a gastro-pub style menu built on small farm raised meats, artisanal breads, and seasonally local produce. We blend our own organic meats for our burgers, honor a Polish family's recipe for authentic pierogies, and hand cut our fries each morning.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Enjoy it all in a polished, warm pub setting -- ebony-stained mahogany, antiqued mirrors, vintage lighting, Audubon lithographs under a hand-patina copper tin ceiling, and our custom-made polished chrome beer tower imported from Germany.
          </p>
          <a href="/sapsuckers/menu/" class="inline-block text-sm font-semibold px-6 py-3 bg-gray-900 text-white rounded hover:bg-gray-700 transition">
            View Our Menu
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <img src="/sapsuckers/SAPSUCKERS5starsv2-50.jpg" alt="Craft beers" class="rounded-lg w-full h-48 object-cover" />
          <img src="/sapsuckers/SAPSUCKERS5starsv2-6.jpg" alt="Gourmet burger" class="rounded-lg w-full h-48 object-cover" />
          <img src="/sapsuckers/SAPSUCKERS5starsv2-20.jpg" alt="Glazed wings" class="rounded-lg w-full h-48 object-cover" />
          <img src="/sapsuckers/SAPSUCKERS5starsv2-17.jpg" alt="Cuban sandwich" class="rounded-lg w-full h-48 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Dishes -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900">From Our Kitchen</h2>
        <p class="mt-3 text-gray-500">Fan favorites and seasonal specialties</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img src="/sapsuckers/SAPSUCKERS5starsv2-8.jpg" alt="Table spread" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img src="/sapsuckers/SAPSUCKERS5starsv2-14.jpg" alt="Chili with cornbread" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img src="/sapsuckers/SAPSUCKERS5starsv2-25.jpg" alt="Dessert" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/sapsuckers/gallery/" class="inline-block text-sm font-semibold px-6 py-3 border border-gray-900 text-gray-900 rounded hover:bg-gray-900 hover:text-white transition">
          View Gallery
        </a>
      </div>
    </div>
  </section>

  <!-- Location Banner -->
  <section class="relative py-20 md:py-28">
    <img
      src="/sapsuckers/SAPSUCKERS5starsv2-70.jpg"
      alt="Sapsuckers booth seating"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 text-center text-white px-4">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">Visit Us in Huntington Village</h2>
      <p class="text-lg opacity-80 mb-2">287 Main St, Huntington, NY 11743</p>
      <p class="text-lg opacity-80 mb-8">(631) 923-3065</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="https://www.ordersapsuckers.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 bg-white text-gray-900 font-semibold rounded hover:bg-gray-100 transition text-sm"
        >
          Order Online
        </a>
        <a
          href="https://www.opentable.com/r/sapsuckers-hops-and-grub-huntington"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 border border-white text-white font-semibold rounded hover:bg-white hover:text-gray-900 transition text-sm"
        >
          Make a Reservation
        </a>
      </div>
    </div>
  </section>
</SapsuckersLayout>
