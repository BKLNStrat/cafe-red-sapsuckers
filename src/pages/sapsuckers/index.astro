---
import SapsuckersLayout from '../../layouts/SapsuckersLayout.astro';
import { sanityClient } from 'sanity:client';
import { getLocation, getSiteContent } from '../../lib/locations';
const loc = await getLocation('sapsuckers');
const content = await getSiteContent('sapsuckers');

let events: any[] = [];
try {
  events = await sanityClient.fetch(
    `*[_type == "event" && restaurant == "sapsuckers" && date >= now()] | order(date asc) [0...3] { title, date, description }`
  ) || [];
} catch (e) { /* no events */ }
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<SapsuckersLayout title="Sapsuckers - Hops & Grub | Huntington, NY" currentPage="home">
  <!-- Hero -->
  <section class="relative h-[70vh] min-h-[500px]">
    <img fetchpriority="high" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-65.jpg`}
      alt="Sapsuckers bar interior"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-white text-center px-4">
      <img loading="lazy" src={`${base}/brand/Sapsuckers_Full_Logo.png`} alt="Sapsuckers Hops & Grub - Huntington, NY" class="h-52 md:h-72 w-auto mb-6 rounded-lg" />
      <h1 class="sr-only">Sapsuckers Hops & Grub</h1>
      <p class="text-lg md:text-xl font-light tracking-widest uppercase opacity-70 mt-2">{content.heroTagline}</p>
      <div class="flex flex-col sm:flex-row gap-3 mt-8">
        <a
          href={loc.orderUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 bg-white text-gray-900 font-semibold rounded hover:bg-gray-100 transition text-sm"
        >
          Order Online
        </a>
        <a
          href={loc.reservationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 border border-white text-white font-semibold rounded hover:bg-white hover:text-gray-900 transition text-sm"
        >
          Make a Reservation
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 md:py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900 mb-6">
            {content.aboutHeading || 'Your Neighborhood Favorite Since 2010'}
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Hatched in September 2010, Sapsuckers has become a neighborhood favorite for awesome hops & grub. We keep sixteen lines of craft beers rotating — all small production and special, many rare and extremely limited. Our Field Guide To Beer gives each one the respect it deserves.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            From the kitchen comes a gastro-pub style menu built on small farm raised meats, artisanal breads, and seasonally local produce. We blend our own organic meats for our burgers, honor a Polish family's recipe for authentic pierogies, and hand cut our fries each morning.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Enjoy it all in a polished, warm pub setting — ebony-stained mahogany, antiqued mirrors, vintage lighting, Audubon lithographs under a hand-patina copper tin ceiling, and our custom-made polished chrome beer tower imported from Germany.
          </p>
          <a href={`${base}/sapsuckers/menu/`} class="inline-block text-sm font-semibold px-6 py-3 bg-gray-900 text-white rounded hover:bg-gray-700 transition">
            View Our Menu
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-50.jpg`} alt="Craft beers" class="rounded-lg w-full h-48 object-cover" />
          <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-6.jpg`} alt="Gourmet burger" class="rounded-lg w-full h-48 object-cover" />
          <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-20.jpg`} alt="Glazed wings" class="rounded-lg w-full h-48 object-cover" />
          <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-17.jpg`} alt="Cuban sandwich" class="rounded-lg w-full h-48 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Dishes -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900">From Our Kitchen</h2>
        <p class="mt-3 text-gray-500">Fan favorites and seasonal specialties</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-8.jpg`} alt="Table spread" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-14.jpg`} alt="Chili with cornbread" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="group relative overflow-hidden rounded-lg aspect-square">
          <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-25.jpg`} alt="Dessert" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
      </div>
      <div class="text-center mt-10">
        <a href={`${base}/sapsuckers/gallery/`} class="inline-block text-sm font-semibold px-6 py-3 border border-gray-900 text-gray-900 rounded hover:bg-gray-900 hover:text-white transition">
          View Gallery
        </a>
      </div>
    </div>
  </section>

  {events.length > 0 && (
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900 mb-8">Upcoming Events</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {events.map((event) => (
            <div class="border border-gray-200 rounded-lg p-6">
              <p class="text-sm text-gray-500 mb-2">{new Date(event.date).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })}</p>
              <h3 class="text-xl font-bold text-gray-900 mb-2">{event.title}</h3>
              {event.description && <p class="text-gray-600">{event.description}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Location Banner -->
  <section class="relative py-20 md:py-28">
    <img loading="lazy" src={`${base}/sapsuckers/SAPSUCKERS5starsv2-70.jpg`}
      alt="Sapsuckers booth seating"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 text-center text-white px-4">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">Visit Us in {loc.city}</h2>
      <p class="text-lg opacity-80 mb-2">{loc.address}, {loc.city}, {loc.state} {loc.zip}</p>
      <p class="text-lg opacity-80 mb-8"><a href={`tel:${loc.phoneTel}`} class="hover:underline">{loc.phone}</a></p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={loc.orderUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 bg-white text-gray-900 font-semibold rounded hover:bg-gray-100 transition text-sm"
        >
          Order Online
        </a>
        <a
          href={loc.reservationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 border border-white text-white font-semibold rounded hover:bg-white hover:text-gray-900 transition text-sm"
        >
          Make a Reservation
        </a>
      </div>
    </div>
  </section>
</SapsuckersLayout>
